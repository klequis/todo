# Turso database URL and auth token.
# For local dev, omit these and the app will use file:data/dev/todo.db instead.
# For staging/prod, set these to your Turso database values.
#
# Get URL:   turso db show <db-name> --url
# Get token: turso db tokens create <db-name>

TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
